# -----------------------------------------------------------------------------
# ai-sec-analyzer - Environment Configuration Template
# Copy this file to '.env.local' or '.env' and populate with your credentials.
# -----------------------------------------------------------------------------

# --- DATABASE CONFIGURATION ---
# PostgreSQL connection string containing pgvector support
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_sec_analyzer"

# --- OPENAI API CONFIGURATION ---
# OpenAI API token required for text-embedding-3-small and gpt-4o calls
OPENAI_API_KEY="your-openai-api-key-here"

# --- BULLMQ ASYNC QUEUE CONFIGURATION ---
# Local/Remote Redis server URL required for BullMQ queues brokers
# Format: redis://[host]:[port] or rediss://[host]:[port] (for secure SSL)
REDIS_URL="redis://127.0.0.1:6379"

# --- UPSTASH REDIS REST CONFIGURATION (RATE LIMITING) ---
# Edge-compatible Upstash Redis REST endpoints for HTTP middleware rate limiters
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token-here"

# --- NEXTAUTH AUTHENTICATION CONFIGURATION ---
# Base deployment URL (e.g. http://localhost:3000 in development, https://your-app.vercel.app in production)
NEXTAUTH_URL="http://localhost:3000"
# High-entropy secret key used to sign NextAuth JSON Web Tokens (JWT)
# Tip: Generate using 'openssl rand -hex 32'
NEXTAUTH_SECRET="your-nextauth-secret-key-32-hex-here"

# --- GITHUB OAUTH CREDENTIALS ---
# GitHub Developer Application Client credentials for secure operator sign-ins
GITHUB_CLIENT_ID="your-github-oauth-client-id-here"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret-here"

# --- GOOGLE OAUTH CREDENTIALS ---
# Google Developer Console Credentials for secure operator sign-ins
GOOGLE_CLIENT_ID="your-google-oauth-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret-here"

# --- OPTIONAL DEPLOYMENT CONFIGURATIONS ---
# Next.js Application Environment (production, development, test)
NODE_ENV="development"
